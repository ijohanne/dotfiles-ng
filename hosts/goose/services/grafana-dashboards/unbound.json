{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } }, "type": "value" }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Status",
      "type": "stat",
      "targets": [{ "expr": "unbound_up{instance=\"$instance\"}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Queries Total",
      "type": "stat",
      "targets": [{ "expr": "sum(unbound_queries_total{instance=\"$instance\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "qps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Queries/sec",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(unbound_queries_total{instance=\"$instance\"}[$__rate_interval]))", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 100 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Unwanted Queries",
      "type": "stat",
      "targets": [{ "expr": "sum(unbound_unwanted_queries_total{instance=\"$instance\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 100 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Unwanted Replies",
      "type": "stat",
      "targets": [{ "expr": "sum(unbound_unwanted_replies_total{instance=\"$instance\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Memory Cache",
      "type": "stat",
      "targets": [{ "expr": "sum(unbound_memory_caches_bytes{instance=\"$instance\"})", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Threads",
      "type": "stat",
      "targets": [{ "expr": "unbound_threads{instance=\"$instance\"}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } } },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "id": 8,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" },
      "title": "Cache Hit Ratio",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(unbound_response_rcodes_total{instance=\"$instance\",rcode=\"NOERROR\"}[$__rate_interval])) / sum(rate(unbound_queries_total{instance=\"$instance\"}[$__rate_interval]))", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Queries",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queries per Second",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(unbound_queries_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "Total", "refId": "A" },
        { "expr": "sum(rate(unbound_cache_hits_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "Cache hits", "refId": "B" },
        { "expr": "sum(rate(unbound_cache_misses_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "Cache misses", "refId": "C" },
        { "expr": "sum(rate(unbound_prefetch_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "Prefetch", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queries by Type",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (type) (rate(unbound_query_types_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "{{type}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queries by Class",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (class) (rate(unbound_query_classes_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "{{class}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queries by Opcode",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (opcode) (rate(unbound_query_opcodes_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "{{opcode}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 14,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queries by Flags",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (flag) (rate(unbound_query_flags_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "{{flag}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 15,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cache Hit/Miss Ratio",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(unbound_cache_hits_total{instance=\"$instance\"}[$__rate_interval])) / (sum(rate(unbound_cache_hits_total{instance=\"$instance\"}[$__rate_interval])) + sum(rate(unbound_cache_misses_total{instance=\"$instance\"}[$__rate_interval])))", "legendFormat": "Hit ratio", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "Response Codes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Response Codes (rate)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (rcode) (rate(unbound_response_rcodes_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "{{rcode}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "SERVFAIL Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(unbound_response_rcodes_total{instance=\"$instance\",rcode=\"SERVFAIL\"}[$__rate_interval]))", "legendFormat": "SERVFAIL/s", "refId": "A" },
        { "expr": "sum(rate(unbound_response_rcodes_total{instance=\"$instance\",rcode=\"NXDOMAIN\"}[$__rate_interval]))", "legendFormat": "NXDOMAIN/s", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "title": "Response Time",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false, "stacking": { "mode": "normal" } }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 30,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Response Time Distribution (rate)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (le) (rate(unbound_response_time_seconds_bucket{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "{{le}}s", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(unbound_response_time_seconds_bucket{instance=\"$instance\"}[$__rate_interval])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum(rate(unbound_response_time_seconds_bucket{instance=\"$instance\"}[$__rate_interval])) by (le))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(unbound_response_time_seconds_bucket{instance=\"$instance\"}[$__rate_interval])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 104,
      "title": "Per Thread",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "id": 40,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queries per Thread",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(unbound_queries_total{instance=\"$instance\"}[$__rate_interval])", "legendFormat": "Thread {{thread}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "id": 41,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Recursion Time per Thread",
      "type": "timeseries",
      "targets": [
        { "expr": "unbound_recursion_time_seconds_avg{instance=\"$instance\"}", "legendFormat": "Thread {{thread}} avg", "refId": "A" },
        { "expr": "unbound_recursion_time_seconds_median{instance=\"$instance\"}", "legendFormat": "Thread {{thread}} median", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "id": 105,
      "title": "Request List",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 58 },
      "id": 50,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Request List",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(unbound_request_list_current_all{instance=\"$instance\"})", "legendFormat": "Current", "refId": "A" },
        { "expr": "sum(unbound_request_list_current_user{instance=\"$instance\"})", "legendFormat": "Current (user)", "refId": "B" },
        { "expr": "sum(rate(unbound_request_list_exceeded_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "Exceeded/s", "refId": "C" },
        { "expr": "sum(rate(unbound_request_list_overwritten_total{instance=\"$instance\"}[$__rate_interval]))", "legendFormat": "Overwritten/s", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 58 },
      "id": 51,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Request List Avg Size",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(unbound_request_list_avg{instance=\"$instance\"})", "legendFormat": "Avg size", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 66 },
      "id": 106,
      "title": "Cache",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 67 },
      "id": 60,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Cache Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "unbound_memory_caches_bytes{instance=\"$instance\"}", "legendFormat": "{{cache}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 67 },
      "id": 61,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "RRset Cache",
      "type": "timeseries",
      "targets": [
        { "expr": "unbound_rrset_cache_count{instance=\"$instance\"}", "legendFormat": "RRset count", "refId": "A" },
        { "expr": "unbound_msg_cache_count{instance=\"$instance\"}", "legendFormat": "Msg cache count", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 75 },
      "id": 107,
      "title": "Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 20, "spanNulls": false }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 76 },
      "id": 70,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Module Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "unbound_memory_modules_bytes{instance=\"$instance\"}", "legendFormat": "{{module}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1, "fillOpacity": 20, "spanNulls": false }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 76 },
      "id": 71,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Sbrk Memory",
      "type": "timeseries",
      "targets": [
        { "expr": "unbound_memory_sbrk_bytes{instance=\"$instance\"}", "legendFormat": "sbrk", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["dns", "unbound"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(unbound_up, instance)",
        "includeAll": false,
        "multi": false,
        "name": "instance",
        "query": { "query": "label_values(unbound_up, instance)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Unbound DNS",
  "uid": "unbound-dns"
}
