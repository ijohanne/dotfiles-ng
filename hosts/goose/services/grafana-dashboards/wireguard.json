{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Peer Status",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "from": 0,
                "to": 0,
                "result": {
                  "text": "Never",
                  "color": "dark-red"
                }
              },
              "type": "range"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "dark-red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "title": "Peer Online Status",
      "description": "Green = handshake within last 3 minutes. Red = stale or never connected.",
      "type": "stat",
      "targets": [
        {
          "expr": "time() - wireguard_latest_handshake_seconds{instance=\"$instance\"} < 180 AND wireguard_latest_handshake_seconds{instance=\"$instance\"} > 0",
          "legendFormat": "{{allowed_ips}}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "calculateField",
          "options": {
            "mode": "reduceRow",
            "reduce": {
              "reducer": "count"
            }
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Handshake Age"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 180
                    },
                    {
                      "color": "red",
                      "value": 300
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Sent"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Received"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 2,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Handshake Age",
            "desc": false
          }
        ]
      },
      "title": "Peer Details",
      "type": "table",
      "targets": [
        {
          "expr": "wireguard_latest_handshake_seconds{instance=\"$instance\"}",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "wireguard_sent_bytes_total{instance=\"$instance\"}",
          "legendFormat": "",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "wireguard_received_bytes_total{instance=\"$instance\"}",
          "legendFormat": "",
          "refId": "C",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "allowed_ips"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "interface 1": true,
              "interface 2": true,
              "interface 3": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "public_key 1": true,
              "public_key 2": true,
              "public_key 3": true,
              "remote_ip 1": true,
              "remote_ip 2": true,
              "remote_ip 3": true,
              "remote_port 1": true,
              "remote_port 2": true,
              "remote_port 3": true
            },
            "renameByName": {
              "allowed_ips": "Peer",
              "Value #A": "Handshake Age",
              "Value #B": "Sent",
              "Value #C": "Received"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Handshake Age",
            "mode": "binary",
            "binary": {
              "left": "Handshake Age",
              "operator": "*",
              "right": "1"
            },
            "replaceFields": false
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "id": 101,
      "title": "Handshakes",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0,
            "spanNulls": false,
            "drawStyle": "points",
            "pointSize": 5
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 10,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Time Since Last Handshake",
      "description": "Should stay under 180s for active peers. 0 = never connected.",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(time() - wireguard_latest_handshake_seconds{instance=\"$instance\"}) and wireguard_latest_handshake_seconds{instance=\"$instance\"} > 0",
          "legendFormat": "{{allowed_ips}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 102,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "id": 20,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Sent to Peers",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(wireguard_sent_bytes_total{instance=\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{allowed_ips}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 27
      },
      "id": 21,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Received from Peers",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(wireguard_received_bytes_total{instance=\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{allowed_ips}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 35
      },
      "id": 22,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Total Throughput (all peers)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(wireguard_sent_bytes_total{instance=\"$instance\"}[$__rate_interval]))",
          "legendFormat": "Sent",
          "refId": "A"
        },
        {
          "expr": "sum(rate(wireguard_received_bytes_total{instance=\"$instance\"}[$__rate_interval]))",
          "legendFormat": "Received",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "id": 103,
      "title": "Cumulative Transfer",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "id": 30,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Total Sent per Peer",
      "type": "timeseries",
      "targets": [
        {
          "expr": "wireguard_sent_bytes_total{instance=\"$instance\"}",
          "legendFormat": "{{allowed_ips}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 44
      },
      "id": 31,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Total Received per Peer",
      "type": "timeseries",
      "targets": [
        {
          "expr": "wireguard_received_bytes_total{instance=\"$instance\"}",
          "legendFormat": "{{allowed_ips}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "wireguard",
    "vpn"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(wireguard_sent_bytes_total, instance)",
        "includeAll": false,
        "multi": false,
        "name": "instance",
        "query": {
          "query": "label_values(wireguard_sent_bytes_total, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "WireGuard",
  "uid": "wireguard",
  "refresh": "30s"
}