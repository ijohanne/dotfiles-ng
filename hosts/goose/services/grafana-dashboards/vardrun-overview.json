{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "System Health Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "beads_repos_tracked_count", "legendFormat": "" }],
      "title": "Tracked Repos",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "beads_reconciler_active_workers", "legendFormat": "Active" },
        { "expr": "beads_repos_errored_total", "legendFormat": "Errored" }
      ],
      "title": "Sync Workers (Active / Errored)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "beads_repos_stale_total", "legendFormat": "" }],
      "title": "Stale Repos",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "Healthy" }, "1": { "text": "Degraded" } }, "type": "value" }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "beads_db_degraded", "legendFormat": "" }],
      "title": "DB Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "beads_dashboard_prom_ex_beam_memory_allocated_bytes", "legendFormat": "" }],
      "title": "BEAM Memory",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "beads_dashboard_prom_ex_beam_stats_process_count", "legendFormat": "" }],
      "title": "BEAM Processes",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Sync Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "rate(beads_sync_completions_total{repo_id=~\"$repo\"}[$__rate_interval])", "legendFormat": "{{slug}} ({{result}})" }
      ],
      "title": "Sync Completions Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 11,
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(beads_sync_duration_seconds_bucket{repo_id=~\"$repo\"}[$__rate_interval]))", "legendFormat": "p50 {{slug}}" },
        { "expr": "histogram_quantile(0.95, rate(beads_sync_duration_seconds_bucket{repo_id=~\"$repo\"}[$__rate_interval]))", "legendFormat": "p95 {{slug}}" },
        { "expr": "histogram_quantile(0.99, rate(beads_sync_duration_seconds_bucket{repo_id=~\"$repo\"}[$__rate_interval]))", "legendFormat": "p99 {{slug}}" }
      ],
      "title": "Sync Duration (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 12,
      "targets": [
        { "expr": "beads_sync_interval_seconds{repo_id=~\"$repo\"}", "legendFormat": "{{slug}}" }
      ],
      "title": "Sync Interval (seconds)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 300,
      "title": "GitHub API",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 20,
      "targets": [
        { "expr": "rate(beads_github_requests_total{slug=~\"$repo\"}[$__rate_interval])", "legendFormat": "{{slug}} {{endpoint}} ({{http_status}})" }
      ],
      "title": "GitHub API Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 21,
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(beads_github_request_duration_seconds_bucket{slug=~\"$repo\"}[$__rate_interval]))", "legendFormat": "p50 {{endpoint}}" },
        { "expr": "histogram_quantile(0.95, rate(beads_github_request_duration_seconds_bucket{slug=~\"$repo\"}[$__rate_interval]))", "legendFormat": "p95 {{endpoint}}" }
      ],
      "title": "GitHub API Latency (p50/p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 100 }, { "color": "green", "value": 1000 }] }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false },
      "targets": [
        { "expr": "beads_github_rate_limit_remaining{slug=~\"$repo\"}", "legendFormat": "{{slug}}" }
      ],
      "title": "Rate Limit Remaining",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 400,
      "title": "Issue Store & ETS",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 30,
      "targets": [
        { "expr": "beads_issues_total{repo_id=~\"$repo\"}", "legendFormat": "{{slug}} ({{status}})" }
      ],
      "title": "Issues by Repo & Status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 31,
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "beads_ets_table_memory_bytes", "legendFormat": "{{table}}" }
      ],
      "title": "ETS Table Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 32,
      "targets": [
        { "expr": "beads_ets_table_size", "legendFormat": "{{table}}" }
      ],
      "title": "ETS Table Entry Counts",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 500,
      "title": "History Writer Queue",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 33 },
      "id": 40,
      "targets": [{ "expr": "beads_history_queue_depth", "legendFormat": "Queue Depth" }],
      "title": "Queue Depth",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 33 },
      "id": 41,
      "targets": [{ "expr": "rate(beads_history_events_flushed_total[$__rate_interval])", "legendFormat": "Flushed/s" }],
      "title": "Events Flushed Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } } },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 33 },
      "id": 42,
      "targets": [{ "expr": "rate(beads_history_events_dropped_total[$__rate_interval])", "legendFormat": "{{reason}}" }],
      "title": "Events Dropped Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 33 },
      "id": 43,
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(beads_history_flush_duration_seconds_bucket[$__rate_interval]))", "legendFormat": "p95" }
      ],
      "title": "Flush Duration p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 600,
      "title": "Auth & Sessions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 42 },
      "id": 50,
      "targets": [
        { "expr": "rate(beads_auth_login_attempts_total[$__rate_interval])", "legendFormat": "{{method}} ({{result}})" }
      ],
      "title": "Login Attempts Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 42 },
      "id": 51,
      "targets": [
        { "expr": "rate(beads_auth_token_refresh_total[$__rate_interval])", "legendFormat": "{{result}}" }
      ],
      "title": "Token Refresh Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 42 },
      "id": 52,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "beads_auth_active_sessions", "legendFormat": "" }],
      "title": "Active Sessions",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 700,
      "title": "gRPC",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "id": 60,
      "targets": [
        { "expr": "rate(beads_grpc_requests_total[$__rate_interval])", "legendFormat": "{{service}}/{{method}} ({{status_code}})" }
      ],
      "title": "gRPC Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 51 },
      "id": 61,
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(beads_grpc_request_duration_seconds_bucket[$__rate_interval]))", "legendFormat": "p50 {{method}}" },
        { "expr": "histogram_quantile(0.95, rate(beads_grpc_request_duration_seconds_bucket[$__rate_interval]))", "legendFormat": "p95 {{method}}" },
        { "expr": "histogram_quantile(0.99, rate(beads_grpc_request_duration_seconds_bucket[$__rate_interval]))", "legendFormat": "p99 {{method}}" }
      ],
      "title": "gRPC Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 51 },
      "id": 62,
      "options": { "yBuckets": { "mode": "linear" } },
      "targets": [
        { "expr": "rate(beads_grpc_request_duration_seconds_bucket[$__rate_interval])", "legendFormat": "{{le}}", "format": "heatmap" }
      ],
      "title": "gRPC Duration Heatmap",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 59 },
      "id": 800,
      "title": "HTTP & LiveView",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 60 },
      "id": 70,
      "targets": [
        { "expr": "rate(beads_dashboard_prom_ex_phoenix_http_request_duration_milliseconds_count[$__rate_interval])", "legendFormat": "{{path}} ({{status}})" }
      ],
      "title": "HTTP Request Rate by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 60 },
      "id": 71,
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(beads_dashboard_prom_ex_phoenix_http_request_duration_milliseconds_bucket[$__rate_interval]))", "legendFormat": "p50 {{path}}" },
        { "expr": "histogram_quantile(0.95, rate(beads_dashboard_prom_ex_phoenix_http_request_duration_milliseconds_bucket[$__rate_interval]))", "legendFormat": "p95 {{path}}" }
      ],
      "title": "HTTP Latency p50/p95 by Route",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 },
      "id": 900,
      "title": "BEAM VM",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 69 },
      "id": 80,
      "targets": [
        { "expr": "beads_dashboard_prom_ex_beam_memory_allocated_bytes", "legendFormat": "total" },
        { "expr": "beads_dashboard_prom_ex_beam_memory_processes_total_bytes", "legendFormat": "processes" },
        { "expr": "beads_dashboard_prom_ex_beam_memory_ets_total_bytes", "legendFormat": "ets" },
        { "expr": "beads_dashboard_prom_ex_beam_memory_binary_total_bytes", "legendFormat": "binary" },
        { "expr": "beads_dashboard_prom_ex_beam_memory_atom_total_bytes", "legendFormat": "atom" }
      ],
      "title": "BEAM Memory by Type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 69 },
      "id": 81,
      "targets": [
        { "expr": "beads_dashboard_prom_ex_beam_stats_process_count", "legendFormat": "Processes" }
      ],
      "title": "BEAM Process Count",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 69 },
      "id": 82,
      "targets": [
        { "expr": "sum(beads_dashboard_prom_ex_beam_stats_run_queue_count)", "legendFormat": "total" },
        { "expr": "beads_dashboard_prom_ex_beam_stats_run_queue_count{type=\"normal\"}", "legendFormat": "cpu" },
        { "expr": "beads_dashboard_prom_ex_beam_stats_run_queue_count{type=\"dirty\"}", "legendFormat": "io" }
      ],
      "title": "BEAM Run Queue Lengths",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["vardrun"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(beads_issues_total, slug)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "repo",
        "query": { "query": "label_values(beads_issues_total, slug)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Vardrun Overview",
  "uid": "vardrun-overview",
  "version": 1
}
