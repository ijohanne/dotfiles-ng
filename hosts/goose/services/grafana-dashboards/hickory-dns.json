        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "rate(recursor_cache_hit_count_total{job=\"hickory-dns\"}[$__rate_interval]) / (rate(recursor_cache_hit_count_total{job=\"hickory-dns\"}[$__rate_interval]) + rate(recursor_cache_miss_count_total{job=\"hickory-dns\"}[$__rate_interval]))",
          "legendFormat": "Cache Hit Ratio",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio",
      "type": "stat"
