        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "rate(hickory_recursor_cache_hit_total{job=\"hickory-dns\"}[5m]) / (rate(hickory_recursor_cache_hit_total{job=\"hickory-dns\"}[5m]) + rate(hickory_recursor_cache_miss_total{job=\"hickory-dns\"}[5m]))",
          "legendFormat": "Cache Hit Ratio",
          "refId": "A"
        }
