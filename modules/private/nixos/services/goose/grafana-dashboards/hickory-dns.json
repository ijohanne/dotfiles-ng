      "targets": [
        {
          "expr": "sum by (code) (rate(hickory_response_codes_total{job=\"hickory-dns\"}[$__rate_interval])) > 0",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "title": "Response Rate (by rcode)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
