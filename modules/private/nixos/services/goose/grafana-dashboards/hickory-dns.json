      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(hickory_recursor_cache_miss_duration_seconds_bucket{job=\"hickory-dns\"}[$__rate_interval]))",
          "legendFormat": "p50 miss",
          "refId": "A"
