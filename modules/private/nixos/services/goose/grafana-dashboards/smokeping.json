        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      },
      "title": "Packet Loss",
      "description": "Instantaneous packet loss rate. Green < 1%, yellow < 5%, red >= 5%.",
      "type": "stat",
      "targets": [
        {
          "expr": "1 - (rate(smokeping_response_duration_seconds_count{instance=\"$instance\"}[$__rate_interval]) / rate(smokeping_requests_total{instance=\"$instance\"}[$__rate_interval]))",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ]
    },
